# =============================================================================
# AI-MOS Backend — Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL values marked with <REPLACE_ME>
#   3. NEVER commit the real `.env` file to version control.
# =============================================================================

# --- Application ---
ENVIRONMENT=development
# Options: development | production

# --- Security ---
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<REPLACE_ME_with_a_64_char_hex_string>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Matches the docker-compose.yml defaults below:
DATABASE_URL=postgresql+asyncpg://aimos_user:aimos_password@localhost:5432/aimos_db

# --- Docker Compose Overrides (used by docker-compose.yml) ---
POSTGRES_DB=aimos_db
POSTGRES_USER=aimos_user
POSTGRES_PASSWORD=aimos_password

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Vite default dev port is 5173.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- pgAdmin (optional, only used if docker-compose pgadmin service is enabled) ---
PGADMIN_EMAIL=admin@aimos.dev
PGADMIN_PASSWORD=admin
