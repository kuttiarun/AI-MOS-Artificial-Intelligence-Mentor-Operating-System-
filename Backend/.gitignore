# =============================================================================
# AI-MOS Backend — .gitignore
# =============================================================================

# --- Secrets (NEVER commit these) ---
.env
.env.local
.env.*.local

# --- Python bytecode ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Build artifacts ---
build/
dist/
*.egg-info/
.eggs/

# --- Testing & Coverage ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# --- Type checker caches ---
.mypy_cache/
.ruff_cache/

# --- Alembic (don't ignore migrations, only generated pycache inside them) ---
# migrations/versions/__pycache__/ is already covered by __pycache__/ above

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
